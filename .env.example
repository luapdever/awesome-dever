# ============================================================
# FRONT (Next.js / web) — copie en .env
# Aucune clé LLM ici : le front ne parle jamais au modèle en direct.
# ============================================================

# Mode SSR / proxy (défaut) : cible Nest sur le réseau interne Docker
CHAT_API_URL=http://api:4000/paulbot/chat

# Mode SPA direct (optionnel) : le navigateur appelle Nest sans passer par Next.
# Décommente et mets l'URL PUBLIQUE de ton backend Nest (CORS requis côté Nest).
# NEXT_PUBLIC_CHAT_URL=https://ton-api.example.com/paulbot/chat

# ============================================================
# SEO — vérification des moteurs de recherche (rendu dans <head>)
# Colle le code fourni par l'outil, puis redéploie. Vide = balise absente.
# ============================================================
# Google Search Console (méthode « balise HTML ») : le contenu du meta google-site-verification
# GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools (meta msvalidate.01)
# BING_SITE_VERIFICATION=
